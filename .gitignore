# Claude Code Configuration - .gitignore

# ==========================================
# 자동 생성 / 캐시 파일
# ==========================================
history.jsonl
*.log
.usage-cache.json

# ==========================================
# 대용량 / 런타임 데이터
# ==========================================
debug/
file-history/
session-env/
shell-snapshots/
todos/
projects/
sessions/
metrics/
homunculus/

# ==========================================
# 플러그인 (마켓플레이스에서 재설치)
# ==========================================
plugins/marketplaces/
plugins/cache/
plugins/known_marketplaces.json
plugins/installed_plugins.json
.omc/

# ==========================================
# 민감 정보 (혹시 모를 경우 대비)
# ==========================================
*.secret
*.key
*credentials*
.env
.env.local
*.pem
*.p12

# ==========================================
# OS 관련
# ==========================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ==========================================
# IDE 관련
# ==========================================
.vscode/
.idea/
*.iml

# ==========================================
# Node.js 관련
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ==========================================
# Backup 파일
# ==========================================
*.bak
*.backup
*.old
